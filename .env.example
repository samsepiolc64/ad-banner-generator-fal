# ============================================================
# fal.ai — generowanie grafik
# ============================================================

# Klucz API fal.ai (wymagany)
FAL_API_KEY=FAL-xxxxxxxxxxxxxxxxxxxx

# Osobny klucz dla trybu prod (opcjonalny — jeśli brak, używany jest FAL_API_KEY)
FAL_PROD_API_KEY=FAL-xxxxxxxxxxxxxxxxxxxx


# ============================================================
# Anthropic Claude — research domeny, generowanie copy, ocena banerów
# ============================================================

# Klucz API Anthropic (opcjonalny — potrzebny do AI research, generate-copy, describe-banner, evaluate-banner, classify-images, describe-materials)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx


# ============================================================
# Supabase — baza danych klientów i kosztów
# ============================================================

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyxxxxxxxxxxxxxxxxxxxx


# ============================================================
# Google Drive — automatyczny zapis grafik w chmurze
# ============================================================

# E-mail konta serwisowego Google (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=nazwa@projekt.iam.gserviceaccount.com

# Klucz prywatny konta serwisowego (cały blok -----BEGIN ... END-----, cudzysłów wymagany)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"

# ID folderu głównego na Google Drive (z URL: drive.google.com/drive/folders/{ID})
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxx


# ============================================================
# ScreenshotOne — zrzuty ekranu stron w research-domain (opcjonalne)
# ============================================================

SCREENSHOTONE_API_KEY=xxxxxxxxxxxxxxxxxxxx
